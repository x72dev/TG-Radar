# ============================================================
#  TG-Radar 项目专属 .gitignore (完全体)
# ============================================================

# --- 核心隐私与凭证 (绝对禁止上传) ---
config.json
*.session
*.session-journal

# --- 敏感部署脚本 ---
push.sh

# --- Python 运行环境 ---
venv/
.env
__pycache__/
*.pyc
*.pyo
*.pyd
*.db

# --- 项目运行临时文件 (新增热重载状态隔离) ---
.silent_start
.last_msg
*.log
logs/

# --- 操作系统与编辑器 ---
Thumbs.db
.DS_Store
.vscode/
.idea/
*.swp

# --- 压缩包与打包文件 ---
*.zip
*.tar.gz
*.7z
.commit_sha
